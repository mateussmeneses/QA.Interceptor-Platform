{
  "manifest_version": 3,
  "name": "QA.Interceptor Platform",
  "version": "0.1.0",
  "description": "QA-focused traffic interception and rule testing extension.",
  "permissions": ["declarativeNetRequest", "storage", "sidePanel", "tabs", "webRequest"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "QA.Interceptor"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content-injector.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/mock-bridge.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "side_panel": {
    "default_path": "dist/sidepanel.html"
  }
}
