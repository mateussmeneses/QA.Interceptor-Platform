{
  "name": "qa-interceptor-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "extension",
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "build": "npm run build -w @qa-interceptor/extension && npm run build -w @qa-interceptor/shared-types && npm run build -w @qa-interceptor/rule-engine",
    "test": "npm run test -w @qa-interceptor/rule-engine",
    "lint": "eslint . --ext .ts,.js,.mjs --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD --verbose"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --max-warnings=0 --fix"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.29.0",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.35.1"
  }
}